# ================================================================
# Plantilla de configuración. Copiar a .env y completar.
# El .env real JAMÁS se versiona ni se incluye en backups (docs/06 §2).
# ================================================================

# --- Entorno ---
ENVIRONMENT=dev                # dev | prod
TZ=America/Santiago

# --- PostgreSQL (contenedor db) ---
POSTGRES_USER=finanzas
POSTGRES_PASSWORD=CAMBIAR-por-password-fuerte
POSTGRES_DB=finanzas

# --- Conexión de la aplicación ---
# Para desarrollo local fuera de Docker (dentro de compose se sobreescribe con host "db"):
DATABASE_URL=postgresql+psycopg://finanzas:CAMBIAR-por-password-fuerte@localhost:5432/finanzas

# --- Logs (docs/10 §2) ---
LOG_LEVEL=INFO
LOG_JSON=true                  # false = salida legible para desarrollo

# --- Usuario por defecto (mono-usuario, ADR-002) ---
DEFAULT_USER_EMAIL=totinunez99@gmail.com

# --- Dashboard ---
API_BASE_URL=http://localhost:8000

# ================================================================
# Secciones futuras (Fase 1 funcional — NO usadas aún):
# IMAP_HOST / IMAP_USER / IMAP_APP_PASSWORD   (conector email, docs/05)
# AI_PROVIDER / ANTHROPIC_API_KEY / ...        (capa IA, docs/04)
# ================================================================
